# ─────────────── Supabase ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────── Upstash Redis ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────── OpenRouter (LLM) ───────────────
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4-mini
OPENROUTER_ALLOCATOR_MODEL=openai/gpt-5.5
OPENROUTER_NARRATOR_MODEL=openai/gpt-5.4-mini

# ─────────────── Email (Resend) ───────────────
RESEND_API_KEY=

# Note: the app's public URL is auto-detected from the incoming request,
# so APP_URL / NEXT_PUBLIC_APP_URL are not needed.
