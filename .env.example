# ─────────────── Supabase ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────── Upstash Redis ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────── OpenRouter (LLM) ───────────────
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_ALLOCATOR_MODEL=openai/gpt-4o
OPENROUTER_NARRATOR_MODEL=openai/gpt-4o-mini

# ─────────────── Email (Resend) ───────────────
RESEND_API_KEY=

# ─────────────── App ───────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────── Admin bootstrap ───────────────
# Used by /login/admin to seed the first admin account on first sign-in.
# Once the admin exists in Supabase Auth + public.users with role='admin',
# these can stay set (the bootstrap is idempotent) or be cleared.
# Password must be at least 8 characters.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Admin
